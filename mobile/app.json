{
  "expo": {
    "name": "Posta",
    "slug": "posta-repartidor",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "lupo",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#141210",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#141210"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lupoenvios.repartidor",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Posta requiere tu ubicación para que puedas usar la app como repartidor y compartir tu posición con logística.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Posta requiere tu ubicación todo el tiempo para el seguimiento en vivo de la flota, con o sin envío activo.",
        "NSCameraUsageDescription": "Posta usa la cámara para escanear etiquetas de Mercado Libre.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "versionCode": 2,
      "package": "com.lupoenvios.repartidor",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#141210"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "expo-task-manager",
      [
        "expo-camera",
        {
          "cameraPermission": "Posta usa la cámara para escanear etiquetas de Mercado Libre."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Posta requiere tu ubicación para que puedas usar la app como repartidor.",
          "locationAlwaysAndWhenInUsePermission": "Posta requiere tu ubicación todo el tiempo para el seguimiento en vivo de la flota.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "apiBaseUrl": "https://envios-erp.up.railway.app",
      "eas": {
        "projectId": "66fe0c44-a8c0-428b-babf-e5de345b6ecd"
      }
    }
  }
}
