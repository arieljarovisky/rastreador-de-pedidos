PORT=4000

# Local
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lupo_tracking

# Railway MySQL (alternativa: el backend también lee MYSQLHOST, MYSQLPORT, etc.)
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_USER=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# DB_NAME=${{MySQL.MYSQLDATABASE}}

JWT_SECRET=cambiar-en-produccion

# Orígenes extra (opcional). Por defecto ya se permiten localhost y Vercel.
# CORS_ORIGIN=http://localhost:5173,https://rastreador-de-pedidos-seven.vercel.app
FRONTEND_URL=https://rastreador-de-pedidos-seven.vercel.app

# Railway: poné true UNA vez, redeployá el backend, y después volvelo a false o borralo
DB_RESET_ON_START=false

# URL pública del backend (OAuth + webhook ML). En Railway se infiere de RAILWAY_PUBLIC_DOMAIN si no está definida.
PUBLIC_URL=http://localhost:4000
# PUBLIC_URL=https://envios-erp.up.railway.app

# App móvil Android (opcional; por defecto se lee backend/downloads/app-version.json)
# MOBILE_APP_VERSION=1.0.0
# MOBILE_APP_MIN_VERSION=1.0.0
FRONTEND_URL=http://localhost:5173

# Mercado Libre — https://developers.mercadolibre.com.ar/devcenter
ML_APP_ID=
ML_APP_SECRET=
# Site de Mercado Libre (MLA = Argentina). Usado al registrar escaneos Flex de mensajería.
# ML_SITE_ID=MLA
# ML_REDIRECT_URI=http://localhost:4000/api/integrations/mercadolibre/callback
# En Mercado Libre → Notificaciones callbacks URL (topics: orders_v2, shipments):
# https://TU-BACKEND/api/integrations/mercadolibre/notifications

# Tienda Nube — https://partners.tiendanube.com
TN_APP_ID=
TN_APP_SECRET=
# TN_REDIRECT_URI=http://localhost:4000/api/integrations/tiendanube/callback
# Webhooks LGPD (obligatorios en el panel de partners):
# https://TU-BACKEND/api/integrations/tiendanube/webhooks/store-redact
# https://TU-BACKEND/api/integrations/tiendanube/webhooks/customers-redact
# https://TU-BACKEND/api/integrations/tiendanube/webhooks/customers-data-request
